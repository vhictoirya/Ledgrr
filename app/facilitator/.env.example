# ─── Solana ────────────────────────────────────────────────────────────────
# Helius RPC (get free key at helius.dev)
HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_API_KEY=YOUR_KEY
HELIUS_WEBHOOK_SECRET=your-webhook-hmac-secret

# x402-network program (update after anchor deploy)
NETWORK_PROGRAM_ID=X4o2NeTWoRK1111111111111111111111111111111
STAKE_MINT=your-stake-token-mint-address

# Facilitator keypair (generated by: solana-keygen new -o facilitator.json)
FACILITATOR_KEYPAIR_PATH=./facilitator.json

# ─── EVM (for settling Base / Avalanche x402 payments) ────────────────────
# Funded EOA — receives USDC via transferWithAuthorization on behalf of merchants
EVM_PRIVATE_KEY=0xYOUR_EVM_PRIVATE_KEY
EVM_WALLET_ADDRESS=0xYourEvmAddress

# ─── Node Config ───────────────────────────────────────────────────────────
PORT=4402
METRICS_PORT=9090
NODE_ENV=development

# Public URL of this node (used for Helius webhook registration)
FACILITATOR_URL=https://your-node.example.com

# Network fee in basis points (7 = 0.07%)
NETWORK_FEE_BPS=7
