{
  "name": "x402-network",
  "version": "0.1.0",
  "private": true,
  "description": "DePIN-style incentivized facilitator network for x402 + MPP micropayments",
  "workspaces": [
    "app/facilitator",
    "app/sdk",
    "app/dashboard"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev:facilitator": "npm run dev --workspace=app/facilitator",
    "dev:dashboard": "npm run dev --workspace=app/dashboard",
    "anchor:build": "anchor build",
    "anchor:test": "anchor test",
    "anchor:deploy:devnet": "anchor deploy --provider.cluster devnet",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.28.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "dotenv": "^17.4.2",
    "get-intrinsic": "^1.3.0",
    "unpipe": "^1.0.0",
    "viem": "^2.47.4"
  }
}
